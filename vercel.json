{
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "wawasrus.com"
        }
      ],
      "destination": "https://www.wawasrus.com/",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "wawasrus.com"
        }
      ],
      "destination": "https://www.wawasrus.com/$1",
      "permanent": true
    },
    {
      "source": "/producto/polera-personalizada-ositos",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/polera-personalizada-ositos",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/products",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/productos",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/ositos-landing",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
